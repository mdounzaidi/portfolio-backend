                  "pm.test('response hides internal security fields', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.not.have.property('failedLoginAttempts');",
                  "  pm.expect(body).to.not.have.property('lockedAt');",
                  "  pm.expect(body).to.not.have.property('lastLoginAt');",
