  "item": [
    {
      "name": "00 - Read Me",
      "item": [
        {
          "name": "How To Use This Collection",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080",
              "host": [
                "http://localhost:8080"
              ]
            },
            "description": "This request is only a note holder. Recommended order: register primary account, paste verification token from email, verify account, then run protected requests. For password reset and invite requests, paste the token from the email into the matching collection variable before running the token-consuming request. Protected endpoints still use Basic Auth until the JWT phase."
          },
          "response": []
        }
      ]
    },
    {
      "name": "01 - Registration and Email Verification",
      "item": [
        {
          "name": "01.01 Register Primary Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('register returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('response is unverified account', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.username).to.eql(pm.collectionVariables.get('primaryUsername'));",
                  "  pm.expect(body.email).to.eql(pm.collectionVariables.get('primaryEmail'));",
                  "  pm.expect(body.emailVerified).to.eql(false);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"username\": \"{{primaryUsername}}\",\n  \"email\": \"{{primaryEmail}}\",\n  \"password\": \"{{primaryPassword}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/public/register",
              "host": [
                "http://localhost:8080"
              ],
              "path": [
                "api",
                "public",
                "register"
              ]
            },
            "description": "Creates the primary account and sends an email verification link. Paste the token from the email into collection variable verificationToken.",
            "auth": {
              "type": "noauth"
            }
          },
          "response": []
        },
        {
