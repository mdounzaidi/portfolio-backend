{
  "info": {
    "name": "Portfolio Backend - Account Flow Tests",
    "description": "Account-focused Postman collection for local testing. Run requests one by one. Tokens for email verification, password reset, and invite completion are sent by email, so paste the raw token from the email link into the matching collection variable before running token-based requests. This collection intentionally excludes article tests and JWT/auth redesign tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "primaryUsername",
      "value": "testuser"
    },
    {
      "key": "primaryPassword",
      "value": "StrongPass@123"
    },
    {
      "key": "primaryNewPassword",
      "value": "StrongPass@456"
    },
    {
      "key": "primaryEmail",
      "value": "testuser@example.com"
    },
    {
      "key": "primaryUpdatedEmail",
      "value": "testuser.updated@example.com"
    },
    {
      "key": "secondaryUsername",
      "value": "seconduser"
    },
    {
      "key": "secondaryEmail",
      "value": "seconduser@example.com"
    },
    {
      "key": "availableUsername",
      "value": "availableuser"
    },
    {
      "key": "adminUsername",
      "value": "adminuser"
    },
    {
      "key": "adminPassword",
      "value": "StrongPass@123"
    },
    {
      "key": "inviteName",
      "value": "Invited User"
    },
    {
      "key": "inviteEmail",
      "value": "invited@example.com"
    },
    {
      "key": "invitedUsername",
      "value": "inviteduser"
    },
    {
      "key": "invitedPassword",
      "value": "StrongPass@123"
    },
    {
      "key": "verificationToken",
      "value": "PASTE_REGISTRATION_VERIFICATION_TOKEN_FROM_EMAIL"
    },
    {
      "key": "updatedEmailVerificationToken",
      "value": "PASTE_UPDATED_EMAIL_VERIFICATION_TOKEN_FROM_EMAIL"
    },
    {
      "key": "resetTokenOne",
      "value": "PASTE_FIRST_PASSWORD_RESET_TOKEN_FROM_EMAIL"
    },
    {
      "key": "resetTokenTwo",
      "value": "PASTE_SECOND_PASSWORD_RESET_TOKEN_FROM_EMAIL"
